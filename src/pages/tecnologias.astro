---
import MainLayout from '@/components/layout/MainLayout.astro';
import Container from '@/components/ui/Container.astro';
import SectionIntro from '@/components/ui/SectionIntro.astro';
import { technologiesByCategory } from '@/data/technologies';
---

<MainLayout
  title="Tecnologías"
  description="Stack tecnológico representativo de SmarSoFT organizado por frontend, backend, datos, infraestructura y calidad."
  pathname="/tecnologias"
>
  <section class="py-20 sm:py-24">
    <Container>
      <SectionIntro
        eyebrow="Tecnologías"
        title="Herramientas y capacidades seleccionadas con criterio práctico."
        description="Trabajamos con tecnologías probadas y decisiones de arquitectura orientadas a rendimiento, mantenibilidad e integración."
      />

      <div class="mt-12 grid gap-6 md:grid-cols-2 xl:grid-cols-3">
        {
          technologiesByCategory.map((group) => (
            <article class="surface-card p-8">
              <h2 class="text-2xl font-bold">{group.category}</h2>
              <ul class="mt-6 list-inside list-disc space-y-3 text-slate-600">
                {group.items.map((item) => <li>{item}</li>)}
              </ul>
            </article>
          ))
        }
      </div>
    </Container>
  </section>
</MainLayout>
