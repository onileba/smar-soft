---
import { siteConfig } from '@/data/site';

interface Props {
  variant?: 'dark' | 'light';
  compact?: boolean;
  withBackground?: boolean;
  class?: string;
}

const {
  variant = 'dark',
  compact = false,
  withBackground = true,
  class: className = '',
} = Astro.props as Props;

const wordmarkTone = variant === 'light' ? 'text-white' : 'text-ink-950';
---

<span
  class:list={[
    'inline-flex items-center rounded-[1.4rem] transition',
    compact ? 'gap-3 px-2.5 py-1' : 'gap-3.5 px-3.5 py-2',
    withBackground && (variant === 'light'
      ? 'bg-[#05202b] ring-1 ring-white/10'
      : 'bg-[#05202b] ring-1 ring-[#05202b]/70 shadow-[0_18px_36px_-24px_rgba(5,32,43,0.8)]'),
    className,
  ]}
>
  <img
    src="/brand/logo-mark-brand.png"
    alt=""
    width={compact ? 56 : 76}
    height={compact ? 70 : 95}
    class:list={[compact ? 'h-14 w-auto' : 'h-20 w-auto', 'shrink-0 rounded-sm object-contain']}
  />
  <span
    class:list={[
      'font-medium tracking-[0.08em]',
      withBackground && variant === 'dark' ? 'text-white' : wordmarkTone,
      compact ? 'text-[1.8rem]' : 'text-3xl',
    ]}
  >
    {siteConfig.name.toUpperCase()}
  </span>
</span>
