---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  align?: 'left' | 'center';
}

const {
  eyebrow,
  title,
  description,
  align = 'left',
} = Astro.props as Props;
---

<div class:list={['max-w-3xl', align === 'center' && 'mx-auto text-center']}>
  {eyebrow && <span class="eyebrow">{eyebrow}</span>}
  <h2 class="mt-4 text-3xl font-bold tracking-tight sm:text-4xl">{title}</h2>
  {description && <p class="mt-4 text-lg leading-8 text-slate-600">{description}</p>}
</div>
