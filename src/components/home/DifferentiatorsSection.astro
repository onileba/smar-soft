---
import Container from '@/components/ui/Container.astro';
import SectionIntro from '@/components/ui/SectionIntro.astro';
import { differentiators } from '@/data/company';
---

<section class="py-16 sm:py-20">
  <Container class="grid gap-8 lg:grid-cols-[0.9fr_1.1fr] lg:items-start">
    <SectionIntro
      eyebrow="Diferenciadores"
      title="Una forma de trabajo sobria, técnica y enfocada en resultados."
      description="Nos importa que la solución sea adecuada al contexto y que el proceso de entrega sea claro para todas las partes."
    />
    <div class="surface-card p-8">
      <ul class="grid gap-4">
        {
          differentiators.map((item) => (
            <li class="rounded-2xl border border-slate-200 bg-slate-50 px-5 py-4 text-slate-700">
              {item}
            </li>
          ))
        }
      </ul>
    </div>
  </Container>
</section>
