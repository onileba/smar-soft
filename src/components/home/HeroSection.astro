---
import Container from '@/components/ui/Container.astro';
import Button from '@/components/ui/Button.astro';
import BrandLogo from '@/components/ui/BrandLogo.astro';
---

<section class="relative overflow-hidden py-20 sm:py-24">
  <div class="absolute inset-x-0 top-0 h-[36rem] bg-[radial-gradient(circle_at_top_right,rgba(0,191,154,0.14),transparent_30%),linear-gradient(180deg,rgba(5,32,43,0.04),transparent)]"></div>
  <Container class="relative grid items-center gap-12 lg:grid-cols-[1.05fr_0.95fr]">
    <div class="max-w-3xl">
      <BrandLogo class="opacity-90" />
      <span class="eyebrow mt-8">Consultoría tecnológica y fábrica de software</span>
      <h1 class="mt-6 text-4xl font-extrabold tracking-tight text-ink-950 sm:text-5xl lg:text-6xl">
        Tecnología sobria, arquitectura clara y ejecución confiable para proyectos que deben funcionar.
      </h1>
      <p class="mt-6 max-w-2xl text-lg leading-8 text-slate-600 sm:text-xl">
        En SmarSoFT acompañamos a organizaciones que necesitan integrar procesos, modernizar
        plataformas y construir software a medida con criterios concretos de mantenibilidad,
        continuidad operativa y valor para negocio.
      </p>
      <div class="mt-6 flex flex-wrap gap-3 text-sm text-slate-600">
        <span class="rounded-full border border-slate-200 bg-white/85 px-3 py-2 shadow-sm">Arquitectura y diagnóstico</span>
        <span class="rounded-full border border-slate-200 bg-white/85 px-3 py-2 shadow-sm">Desarrollo a medida</span>
        <span class="rounded-full border border-slate-200 bg-white/85 px-3 py-2 shadow-sm">Integración y modernización</span>
      </div>
      <div class="mt-8 flex flex-wrap gap-4">
        <Button href="/contacto">Hablemos de su proyecto</Button>
        <Button href="/servicios" variant="secondary">Ver servicios</Button>
      </div>
    </div>

    <div class="relative">
      <div class="surface-card overflow-hidden p-0">
        <div class="relative aspect-[4/4.6] sm:aspect-[4/4]">
          <img
            src="/brand/office-hero.jpg"
            alt="Aplicación principal del logotipo SmarSoFT en un espacio corporativo sobrio."
            width="3840"
            height="2160"
            loading="eager"
            class="absolute inset-0 h-full w-full object-cover"
          />
          <div class="absolute inset-0 bg-gradient-to-tr from-ink-950/90 via-ink-950/38 to-transparent"></div>
          <div class="absolute inset-x-0 top-0 h-1 bg-gradient-to-r from-brand-400 via-brand-300 to-white/60"></div>
          <div class="absolute inset-x-0 bottom-0 p-7 sm:p-8">
            <div class="max-w-md rounded-[1.75rem] border border-white/12 bg-ink-950/78 p-6 text-slate-200 backdrop-blur-sm">
              <p class="text-xs font-semibold uppercase tracking-[0.24em] text-brand-300">Dirección de entrega</p>
              <p class="mt-4 text-2xl font-semibold tracking-tight text-white">
                Soluciones discretas en forma, rigurosas en ejecución.
              </p>
              <p class="mt-4 text-sm leading-7 text-slate-300">
                Diseño funcional, criterio de arquitectura y entregables listos para integrarse a procesos reales.
              </p>
            </div>
          </div>
        </div>
      </div>
      <div class="mt-5 grid gap-4 sm:grid-cols-3">
        <div class="surface-card px-5 py-4">
          <p class="text-sm font-semibold text-brand-700">Consultoría técnica</p>
          <p class="mt-2 text-sm leading-6 text-slate-600">Diagnóstico, arquitectura y hoja de ruta con criterio de prioridad.</p>
        </div>
        <div class="surface-card px-5 py-4">
          <p class="text-sm font-semibold text-brand-700">Integración y evolución</p>
          <p class="mt-2 text-sm leading-6 text-slate-600">Modernización pragmática de plataformas y procesos existentes.</p>
        </div>
        <div class="surface-card bg-ink-950 px-5 py-4 text-slate-200">
          <p class="text-sm font-semibold text-brand-300">Entrega responsable</p>
          <p class="mt-2 text-sm leading-6 text-slate-300">Ejecución clara, estable y lista para producción.</p>
        </div>
      </div>
    </div>
  </Container>
</section>
