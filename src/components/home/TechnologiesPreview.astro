---
import Container from '@/components/ui/Container.astro';
import SectionIntro from '@/components/ui/SectionIntro.astro';
import Button from '@/components/ui/Button.astro';
import { technologiesByCategory } from '@/data/technologies';
---

<section class="py-16 sm:py-20">
  <Container>
    <div class="flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between">
      <SectionIntro
        eyebrow="Tecnologías"
        title="Stack representativo para construir soluciones modernas y mantenibles."
        description="Seleccionamos herramientas según necesidad real, complejidad operativa y sostenibilidad a mediano plazo."
      />
      <Button href="/tecnologias" variant="secondary">Ver stack completo</Button>
    </div>

    <div class="mt-10 grid gap-6 md:grid-cols-2 xl:grid-cols-5">
      {
        technologiesByCategory.map((group) => (
          <article class="surface-card p-6">
            <h3 class="text-lg font-bold">{group.category}</h3>
            <ul class="mt-5 list-inside list-disc space-y-2 text-sm text-slate-600">
              {group.items.map((item) => <li>{item}</li>)}
            </ul>
          </article>
        ))
      }
    </div>
  </Container>
</section>
